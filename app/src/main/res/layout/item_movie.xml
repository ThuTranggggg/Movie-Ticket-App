<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/space_16"
    app:cardBackgroundColor="@color/color_card"
    app:cardCornerRadius="@dimen/radius_large"
    app:strokeColor="@color/color_stroke">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/space_16">

        <ImageView
            android:id="@+id/imgPoster"
            android:layout_width="110dp"
            android:layout_height="@dimen/poster_item_height"
            android:background="@drawable/bg_poster_placeholder"
            android:scaleType="centerCrop"
            tools:ignore="ContentDescription" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_16"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/color_text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                tools:text="The Batman" />

            <TextView
                android:id="@+id/txtGenreDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                android:background="@drawable/bg_badge"
                android:paddingStart="@dimen/space_12"
                android:paddingTop="@dimen/space_8"
                android:paddingEnd="@dimen/space_12"
                android:paddingBottom="@dimen/space_8"
                android:textColor="@color/color_text_primary"
                tools:text="Action • 176 min" />

            <TextView
                android:id="@+id/txtRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                android:textColor="@color/color_secondary"
                android:textStyle="bold"
                tools:text="⭐ 8.6" />

            <TextView
                android:id="@+id/txtDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:maxLines="3"
                android:textColor="@color/color_text_secondary"
                android:textSize="14sp"
                tools:text="A dark and premium detective thriller set in Gotham..." />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBook"
                style="@style/Widget.MovieVerse.Button.Primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16"
                android:text="@string/book_now" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
