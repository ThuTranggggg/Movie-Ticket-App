<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:navigationIcon="@android:drawable/ic_media_previous"
            android:title="@string/book_ticket" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_20">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_surface_card"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_16">

                    <ImageView
                        android:id="@+id/imgMoviePoster"
                        android:layout_width="90dp"
                        android:layout_height="120dp"
                        android:background="@drawable/bg_poster_placeholder"
                        android:scaleType="centerCrop"
                        tools:ignore="ContentDescription" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_16"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/txtMovieTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/color_text_primary"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            tools:text="Interstellar" />

                        <TextView
                            android:id="@+id/txtMovieMeta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_8"
                            android:textColor="@color/color_text_secondary"
                            tools:text="Sci-Fi • 169 min" />

                        <TextView
                            android:id="@+id/txtMovieRating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_8"
                            android:background="@drawable/bg_badge_warning"
                            android:paddingStart="@dimen/space_12"
                            android:paddingTop="@dimen/space_8"
                            android:paddingEnd="@dimen/space_12"
                            android:paddingBottom="@dimen/space_8"
                            android:textColor="@color/color_white"
                            tools:text="⭐ 8.9" />
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutDate"
                    style="@style/Widget.MovieVerse.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_20"
                    android:hint="@string/select_date"
                    app:startIconDrawable="@android:drawable/ic_menu_today">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtSelectedDate"
                        style="@style/Widget.MovieVerse.TextInputEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:enabled="false"
                        android:focusable="false" />
                </com.google.android.material.textfield.TextInputLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerDates"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_date_option" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutTheater"
                    style="@style/Widget.MovieVerse.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_20"
                    android:hint="@string/select_theater"
                    app:endIconMode="dropdown_menu"
                    app:startIconDrawable="@android:drawable/ic_menu_mylocation">

                    <AutoCompleteTextView
                        android:id="@+id/autoTheater"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:paddingTop="@dimen/space_16"
                        android:paddingBottom="@dimen/space_16"
                        android:textColor="@color/color_text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/txtShowtimeState"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:text="@string/choose_date_first"
                    android:textColor="@color/color_text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_20"
                    android:text="@string/select_showtime"
                    android:textColor="@color/color_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerShowtimes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_showtime" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_24"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="160dp"
                        android:layout_height="12dp"
                        android:background="@drawable/bg_screen" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_8"
                        android:text="@string/screen_label"
                        android:textColor="@color/color_text_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_16"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_seat_available"
                        android:paddingStart="@dimen/space_8"
                        android:paddingTop="@dimen/space_4"
                        android:paddingEnd="@dimen/space_8"
                        android:paddingBottom="@dimen/space_4"
                        android:text="Available"
                        android:textColor="@color/color_text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_8"
                        android:background="@drawable/bg_seat_selected"
                        android:paddingStart="@dimen/space_8"
                        android:paddingTop="@dimen/space_4"
                        android:paddingEnd="@dimen/space_8"
                        android:paddingBottom="@dimen/space_4"
                        android:text="Selected"
                        android:textColor="@color/color_white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_8"
                        android:background="@drawable/bg_seat_booked"
                        android:paddingStart="@dimen/space_8"
                        android:paddingTop="@dimen/space_4"
                        android:paddingEnd="@dimen/space_8"
                        android:paddingBottom="@dimen/space_4"
                        android:text="Booked"
                        android:textColor="@color/color_white" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerSeats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_16"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_seat" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_24"
                    app:cardBackgroundColor="@color/color_card"
                    app:cardCornerRadius="@dimen/radius_large"
                    app:strokeColor="@color/color_stroke">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_20">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/booking_summary"
                            android:textColor="@color/color_text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtSelectedShowtime"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_12"
                            android:textColor="@color/color_text_secondary"
                            tools:text="Showtime: 19:30, Apr 09" />

                        <TextView
                            android:id="@+id/txtSelectedSeats"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_8"
                            android:textColor="@color/color_text_secondary"
                            tools:text="Selected: A1, A2" />

                        <TextView
                            android:id="@+id/txtQuantity"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_8"
                            android:textColor="@color/color_text_secondary"
                            tools:text="2 ticket(s)" />

                        <TextView
                            android:id="@+id/txtTotalPrice"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_12"
                            android:textColor="@color/color_text_primary"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            tools:text="$24.00" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </ScrollView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmBooking"
            style="@style/Widget.MovieVerse.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/space_20"
            android:text="@string/confirm_booking" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/color_overlay"
        android:visibility="gone">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:indicatorColor="@color/color_secondary" />
    </FrameLayout>
</FrameLayout>
