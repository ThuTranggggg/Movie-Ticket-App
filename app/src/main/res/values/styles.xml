<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.MovieVerse.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="titleTextColor">@color/color_text_primary</item>
        <item name="subtitleTextColor">@color/color_text_secondary</item>
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="Widget.MovieVerse.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/color_surface_alt</item>
        <item name="boxStrokeColor">@color/color_stroke</item>
        <item name="hintTextColor">@color/color_text_hint</item>
        <item name="android:textColorHint">@color/color_text_hint</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.MovieVerse.Input</item>
        <item name="errorTextColor">@color/color_error</item>
        <item name="helperTextTextColor">@color/color_text_secondary</item>
    </style>

    <style name="Widget.MovieVerse.TextInputEditText" parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="android:textColor">@color/color_text_primary</item>
        <item name="android:textColorHint">@color/color_text_hint</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="Widget.MovieVerse.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:textAllCaps">false</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.MovieVerse.Button</item>
        <item name="backgroundTint">@color/color_primary</item>
        <item name="android:textColor">@color/color_white</item>
    </style>

    <style name="Widget.MovieVerse.Button.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:textAllCaps">false</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.MovieVerse.Button</item>
        <item name="strokeColor">@color/color_stroke</item>
        <item name="android:textColor">@color/color_text_primary</item>
    </style>

    <style name="Widget.MovieVerse.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/color_card</item>
        <item name="strokeColor">@color/color_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="TextAppearance.MovieVerse.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/color_text_primary</item>
    </style>

    <style name="TextAppearance.MovieVerse.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/color_text_primary</item>
    </style>

    <style name="TextAppearance.MovieVerse.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/color_text_secondary</item>
    </style>

    <style name="ShapeAppearance.MovieVerse" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_medium</item>
    </style>

    <style name="ShapeAppearance.MovieVerse.Button" parent="@style/ShapeAppearance.MovieVerse">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_medium</item>
    </style>

    <style name="ShapeAppearance.MovieVerse.Input" parent="@style/ShapeAppearance.MovieVerse">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_medium</item>
    </style>
</resources>
